    "frage": "Codehack",
    "antwort": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<title>PIN</title>\n\n<style>\nbody{\n    background:black;\n    color:#00ff00;\n    font-family:monospace;\n    text-align:center;\n    padding-top:50px;\n}\n\ninput,button{\n    padding:12px;\n    font-size:18px;\n    margin:10px;\n}\n\nbutton{\n    background:#00ff00;\n    border:none;\n    cursor:pointer;\n}\n\n#console{\n    margin-top:30px;\n    font-size:20px;\n}\n\n.red{\n    color:red;\n}\n</style>\n</head>\n\n<body>\n\n<h1>PIN</h1>\n\n<p>JSON Datei hochladen:</p>\n\n<input type=\"file\" id=\"file\" accept=\".json\">\n\n<br>\n\n<button id=\"hack\" style=\"display:none;\">\nHacken\n</button>\n\n<div id=\"console\"></div>\n\n<h2 id=\"tries\">Versuche: 0</h2>\n\n\n<script>\n\nlet geheim = [];\nlet versuche = 0;\nlet interval;\n\n\n// JSON laden\ndocument.getElementById(\"file\").onchange = function(e){\n\n    let reader = new FileReader();\n\n    reader.onload = function(){\n\n        let daten = JSON.parse(reader.result);\n\n        geheim = daten.zahlen;\n\n        document.getElementById(\"console\").innerHTML =\n        \"JSON geladen ✔<br>Bereit für Simulation\";\n\n        document.getElementById(\"hack\").style.display=\"inline-block\";\n\n    };\n\n    reader.readAsText(e.target.files[0]);\n\n};\n\n\n// Fake Hack starten\ndocument.getElementById(\"hack\").onclick=function(){\n\n    document.getElementById(\"hack\").disabled=true;\n\n    document.getElementById(\"console\").innerHTML =\n    \"Starte Fake-Hacking...\";\n\n\n    interval=setInterval(()=>{\n\n        // 5 Fake Versuche pro Millisekunde simulieren\n        versuche += 5;\n\n        document.getElementById(\"tries\").innerHTML =\n        \"Versuche: \" + versuche;\n\n\n        // zufällige Fake-Kombination\n        let test=[];\n\n        for(let i=0;i<10;i++){\n            test.push(Math.floor(Math.random()*100));\n        }\n\n\n        // prüfen\n        if(JSON.stringify(test)==JSON.stringify(geheim)){\n\n            clearInterval(interval);\n\n            document.getElementById(\"console\").innerHTML =\n            \"<span class='red'>FAKE ERFOLG! Kombination gefunden!</span>\";\n\n        }\n\n\n    },1);\n\n};\n\n</script>\n\n</body>\n</html>"
