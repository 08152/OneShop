    "antwort": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Terminal</title>\n\n<style>\n*{\n    margin:0;\n    padding:0;\n    box-sizing:border-box;\n}\n\nbody{\n    background:black;\n    color:#00ff00;\n    font-family:monospace;\n    height:100vh;\n    overflow:hidden;\n}\n\n#terminal{\n    padding:20px;\n    font-size:20px;\n    white-space:pre-wrap;\n    height:100vh;\n}\n\n#prank{\n    display:none;\n    position:absolute;\n    top:50%;\n    left:50%;\n    transform:translate(-50%,-50%);\n    font-size:80px;\n    color:red;\n    font-family:Arial, sans-serif;\n    font-weight:bold;\n    text-shadow:0 0 20px red;\n}\n\n.glitch{\n    animation:glitch 0.08s infinite;\n}\n\n@keyframes glitch{\n    0%{\n        transform:translate(0,0);\n        filter:hue-rotate(0deg);\n    }\n    25%{\n        transform:translate(10px,-5px);\n        filter:hue-rotate(90deg);\n    }\n    50%{\n        transform:translate(-10px,5px);\n        filter:hue-rotate(180deg);\n    }\n    75%{\n        transform:translate(5px,10px);\n        filter:hue-rotate(270deg);\n    }\n    100%{\n        transform:translate(0,0);\n        filter:hue-rotate(360deg);\n    }\n}\n\n.scan{\n    color:#00ff00;\n}\n</style>\n\n</head>\n\n<body>\n\n<div id=\"terminal\"></div>\n<div id=\"Error 404\"</div>\n\n\n<script>\n\nlet terminal = document.getElementById(\"terminal\");\nlet prank = document.getElementById(\"prank\");\n\n\n// Start Text\nterminal.innerHTML =\n\"Initializing system...\\n\"+\n\"Loading security modules...\\n\"+\n\"Connecting...\\n\"+\n\"Accessing files...\\n\\n\";\n\n\n// Nach 2 Sekunden Zahlen starten\nsetTimeout(()=>{\n\n    let zahlen = setInterval(()=>{\n\n        let zahl = Math.floor(Math.random()*999999);\n        terminal.innerHTML += zahl + \"\\n\";\n\n        // Scroll Effekt\n        terminal.scrollTop = terminal.scrollHeight;\n\n    },1);\n\n\n    // Nach 3 Sekunden Glitch\n    setTimeout(()=>{\n\n        clearInterval(zahlen);\n\n        document.body.classList.add(\"glitch\");\n        terminal.classList.add(\"glitch\");\n\n        terminal.innerHTML +=\n        \"\\nSYSTEM ERROR...\\n\"+\n        \"UNKNOWN PROCESS...\\n\"+\n        \"WARNING...\\n\";\n\n\n        // Nach kurzer Zeit PRANK anzeigen\n        setTimeout(()=>{\n\n            terminal.style.display=\"none\";\n            prank.style.display=\"block\";\n\n        },2000);\n\n\n    },3000);\n\n\n},2000);\n\n\n</script>\n\n</body>\n</html>"
