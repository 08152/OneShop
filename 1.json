    "antwort": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Virus Scanner</title>\n\n<style>\nbody{\n    margin:0;\n    height:100vh;\n    background:#111;\n    color:white;\n    font-family:Arial, sans-serif;\n    display:flex;\n    justify-content:center;\n    align-items:center;\n}\n\n.container{\n    text-align:center;\n}\n\nbutton{\n    padding:20px 40px;\n    font-size:25px;\n    border:none;\n    border-radius:10px;\n    cursor:pointer;\n    background:#00aa00;\n    color:white;\n}\n\nbutton:hover{\n    background:#00dd00;\n}\n\n#scan{\n    display:none;\n    margin-top:30px;\n}\n\n.loader{\n    border:10px solid #333;\n    border-top:10px solid #00ff00;\n    border-radius:50%;\n    width:80px;\n    height:80px;\n    animation: drehen 1s linear infinite;\n    margin:auto;\n}\n\n@keyframes drehen{\n    100%{\n        transform:rotate(360deg);\n    }\n}\n\n#percent{\n    font-size:35px;\n    margin-top:20px;\n}\n\n#virus{\n    display:none;\n    color:red;\n    font-size:40px;\n    font-weight:bold;\n    margin-top:30px;\n}\n</style>\n\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<h1>Antivirus</h1>\n\n<button onclick=\"startScan()\">PC scannen</button>\n\n<div id=\"scan\">\n    <div class=\"loader\"></div>\n    <div id=\"percent\">0%</div>\n</div>\n\n<div id=\"virus\">\n    ⚠ Virus erkannt\n</div>\n\n</div>\n\n\n<script>\n\nfunction startScan(){\n\n    document.querySelector(\"button\").style.display=\"none\";\n    document.getElementById(\"scan\").style.display=\"block\";\n\n    let zahl = 0;\n\n    let timer = setInterval(()=>{\n\n        zahl += Math.floor(Math.random()*10)+1;\n\n        if(zahl >= 100){\n            zahl = 100;\n            clearInterval(timer);\n\n            setTimeout(()=>{\n\n                document.getElementById(\"scan\").style.display=\"none\";\n                document.getElementById(\"virus\").style.display=\"block\";\n\n            },500);\n        }\n\n        document.getElementById(\"percent\").innerHTML = zahl + \"%\";\n\n    },300);\n\n}\n\n</script>\n\n</body>\n</html>"
