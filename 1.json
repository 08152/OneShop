    "frage": "Erstelle mir etwas verstörendes",
    "antwort": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Jumpscare</title>\n\n<style>\nbody{\n    margin:0;\n    height:100vh;\n    background:black;\n    display:flex;\n    justify-content:center;\n    align-items:center;\n    color:white;\n    font-family:Arial;\n}\n\n#text{\n    font-size:40px;\n}\n\n#jumpscare{\n    display:none;\n    position:fixed;\n    inset:0;\n    background:black;\n    justify-content:center;\n    align-items:center;\n    animation:shake 0.1s infinite;\n}\n\n.face{\n    width:300px;\n    height:300px;\n    background:white;\n    border-radius:50%;\n    position:relative;\n}\n\n.eye{\n    position:absolute;\n    top:80px;\n    width:50px;\n    height:70px;\n    background:black;\n    border-radius:50%;\n}\n\n.left{\n    left:70px;\n}\n\n.right{\n    right:70px;\n}\n\n.mouth{\n    position:absolute;\n    bottom:50px;\n    left:70px;\n    width:160px;\n    height:50px;\n    background:black;\n    border-radius:0 0 80px 80px;\n}\n\n@keyframes shake{\n    0%{transform:translate(5px,5px);}\n    50%{transform:translate(-5px,-5px);}\n    100%{transform:translate(0,0);}\n}\n</style>\n\n</head>\n\n<body>\n\n<div id=\"text\">Warte...</div>\n\n<div id=\"jumpscare\">\n    <div class=\"face\">\n        <div class=\"eye left\"></div>\n        <div class=\"eye right\"></div>\n        <div class=\"mouth\"></div>\n    </div>\n</div>\n\n<script>\nsetTimeout(()=>{\n    document.getElementById(\"text\").style.display=\"none\";\n    document.getElementById(\"jumpscare\").style.display=\"flex\";\n},3000);\n</script>\n\n</body>\n</html>"
