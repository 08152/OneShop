ocument.body.classList.add(\"glitch\");\n        terminal.classList.add(\"glitch\");\n\n        terminal.innerHTML +=\n        \"\\nSYSTEM ERROR...\\n\"+\n        \"UNKNOWN PROCESS...\\n\"+\n        \"WARNING...\\n\";\n\n\n        // Nach kurzer Zeit PRANK anzeigen\n        setTimeout(()=>{\n\n            terminal.style.display=\"none\";\n            prank.style.display=\"block\";\n\n        },2000);\n\n\n    },3000);\n\n\n},2000);\n\n\n</script>\n\n</body>\n</html>"
